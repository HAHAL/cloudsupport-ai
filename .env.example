# CloudSupport AI environment example
# Rule-based workflows can run without external model credentials.

LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# OPENAI_API_KEY=
# DASHSCOPE_API_KEY=

KNOWLEDGE_DIR=/app/knowledge
CHROMA_DIR=/app/chroma_data
CHROMA_COLLECTION=cloudsupport_kb
RAG_TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=120
FEEDBACK_FILE=/app/data/answer_feedback.jsonl
